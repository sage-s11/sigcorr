<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{20} - %msg%n</pattern>
        </encoder>
    </appender>
    <logger name="io.sigcorr" level="INFO"/>
    <logger name="io.sigcorr.protocol" level="WARN"/>
    <logger name="io.sigcorr.ingest.tshark" level="INFO"/>
    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
